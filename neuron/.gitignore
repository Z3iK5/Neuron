# Neuron-specific ignores (in addition to the repository-root .gitignore).

# Python virtual environments
.venv/
venv/

# Local secrets / environment files (NEVER commit these)
.env
**/.env
!**/.env.example

# Python build / cache artifacts
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Desktop installer build outputs (built in CI / locally, never committed)
*.AppImage
*.dmg
*.msix
*.cer
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local dev stack data (generated homeserver config, signing keys, DB volumes if bind-mounted)
deploy/compose/homeserver-data/
deploy/compose/synapse-data/
deploy/compose/data/

# Auditor runtime artifacts (resume token + local audit log)
auditor-state.json
auditor-state.json.tmp
audit-log.jsonl
