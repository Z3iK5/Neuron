# Local dev stack configuration. Copy this file to `.env` and edit the values.
#
#   cp .env.example .env
#
# The real `.env` file is git-ignored — NEVER commit it. These are throwaway
# DEV-ONLY values for a local homeserver; do not reuse them in production.

# --- Synapse ---------------------------------------------------------------
# The homeserver name. For local dev a made-up name like "neuron.local" is fine.
SYNAPSE_SERVER_NAME=neuron.local

# A shared secret that lets you register users from the command line
# (register_new_matrix_user). Generate a random one, e.g.:  openssl rand -hex 32
REGISTRATION_SHARED_SECRET=change-me-dev-only

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_USER=synapse
# Generate a random one, e.g.:  openssl rand -hex 16
POSTGRES_PASSWORD=change-me-dev-only
POSTGRES_DB=synapse
