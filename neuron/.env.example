# Copy to `.env` and edit, then: docker compose up -d --build
# (.env is git-ignored; .env.example is the documented template.)

# The homeserver's permanent identity — the domain part of every Matrix ID it
# owns (@alice:YOUR.DOMAIN). Set this BEFORE first start; it cannot change once
# the database is initialized.
NEURON_SERVER_NAME=neuron.local

# Public URL clients use to reach the Client-Server API (advertised via
# /.well-known/matrix/client). Use your real https:// URL in production.
NEURON_SERVER_PUBLIC_BASE_URL=http://localhost:8008

# Host port to publish the homeserver on.
NEURON_PORT=8008

# PostgreSQL password (used by both the db service and the app's DATABASE_URL).
# Change this to a strong value.
POSTGRES_PASSWORD=neuron

# PostgreSQL connection-pool size for the app process. Safe to raise above 1 for
# write concurrency (the multi-writer position tracker handles ordering).
NEURON_SERVER_DB_POOL_SIZE=8

# Secret that signs admin-console session cookies. Set a stable random value so
# operators stay logged in across restarts, e.g.:  openssl rand -hex 32
NEURON_SERVER_CONSOLE_SESSION_SECRET=

# --- Behind a reverse proxy (TLS) ---
# When a proxy (Caddy/nginx/Traefik) terminates TLS in front of Neuron, trust its
# X-Forwarded-* headers so the real client IP/scheme is used. List the proxy's
# IP(s), comma-separated; "*" trusts any peer (only when Neuron is reachable solely
# through the proxy). Leave EMPTY for a directly-exposed server (else IPs can be
# spoofed). Example for a proxy container on this compose network:
# NEURON_SERVER_TRUSTED_PROXIES=*
NEURON_SERVER_TRUSTED_PROXIES=

# Mark the console session cookie Secure (HTTPS-only). Set true in production.
NEURON_SERVER_SESSION_HTTPS_ONLY=false
